[Unit]
Description=Xorg server
ConditionPathExists=/dev/tty1

[Service]
Type=notify
NotifyAccess=all
Environment=DISPLAY=:0
Environment=XAUTHORITY=%h/.Xauthority
ExecStart=%h/.local/bin/x11-launch :0 vt7 -keeptty -nolisten tcp -dpi 192

Restart=on-failure
RestartSec=1s

KillMode=control-group
KillSignal=SIGTERM
TimeoutStopSec=5


[Install]
WantedBy=graphical-session.target
